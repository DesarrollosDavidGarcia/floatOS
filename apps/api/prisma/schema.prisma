// FlotaOS — Modelo de datos (Prisma)
// Despliegue instancia-por-cliente: SIN tenantId, la BD ya está aislada por diseño.
// PostGIS está habilitado en la BD (ver postgres/init.sql). Las coordenadas se
// guardan como Float (gestionadas por Prisma) y, donde se necesitan consultas
// geográficas (distancia/geocercas), una columna `geography` GENERADA por SQL
// (declarada como Unsupported(...) @ignore) alimenta índices GIST y ST_Distance/ST_DWithin.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

enum EstadoViaje {
  ASIGNADO
  ACEPTADO
  EN_CAMINO_ORIGEN
  CARGANDO
  EN_TRANSITO
  ENTREGADO
  FACTURADO
  CANCELADO
}

enum TipoDocumentoUnidad {
  VERIFICACION
  SEGURO
  TARJETA_CIRCULACION
  OTRO
}

enum TipoDocumentoConductor {
  LICENCIA_FEDERAL
  EXAMEN_MEDICO
  INE
  CURP
  RFC
  COMPROBANTE_DOMICILIO
  CONSTANCIA_SITUACION_FISCAL
  CONTRATO
  ALTA_IMSS
  OTRO
}

/// Categoría de la Licencia Federal de Conductor (SCT autotransporte federal).
enum CategoriaLicencia {
  A
  B
  C
  D
  E
  F
}

/// Tipo de examen del expediente médico (análisis continuo del conductor).
enum TipoExamenMedico {
  APTITUD_PSICOFISICA
  ANTIDOPING
  EXAMEN_GENERAL
  VISTA
  AUDITIVO
  OTRO
}

/// Resultado/dictamen de un examen médico o de control de confianza.
enum ResultadoExamen {
  APTO
  NO_APTO
  CONDICIONADO
  PENDIENTE
}

/// Tipo de certificación formal del conductor.
enum TipoCertificacion {
  MATERIALES_PELIGROSOS
  RESIDUOS_PELIGROSOS
  MANEJO_DEFENSIVO
  PRIMEROS_AUXILIOS
  CAAT
  MERCANCIAS_PELIGROSAS_SCT
  OTRO
}

/// Tipo de incidencia registrada en el expediente (positivas y negativas).
enum TipoIncidencia {
  ACCIDENTE
  INFRACCION
  SANCION
  FALTA
  QUEJA
  RECONOCIMIENTO
  OTRO
}

/// Gravedad de una incidencia.
enum GravedadIncidencia {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

/// Evento en la trayectoria del conductor dentro de la empresa.
enum TipoEventoLaboral {
  INGRESO
  ASCENSO
  CAMBIO_PUESTO
  CAMBIO_SALARIO
  AMONESTACION
  RECONOCIMIENTO
  BAJA
  OTRO
}

/// Nivel de aptitud del conductor para un tipo de unidad.
enum NivelAptitud {
  PRINCIPIANTE
  INTERMEDIO
  EXPERTO
}

/// Tipo de unidad de transporte que el conductor maneja con frecuencia.
enum TipoUnidadManejo {
  TRACTOCAMION
  TORTON
  RABON
  THORTON
  CAMION_3_5
  CAMIONETA
  CAJA_SECA
  CAJA_REFRIGERADA
  PLATAFORMA
  TOLVA
  PIPA
  FULL
  OTRO
}

/// Tipo de evaluación de control de confianza.
enum TipoControlConfianza {
  EXAMEN_CONFIANZA
  ANTECEDENTES_NO_PENALES
  ESTUDIO_SOCIOECONOMICO
  POLIGRAFO
  TOXICOLOGICO
  OTRO
}

/// Tipo de ausencia/asistencia registrada.
enum TipoAusencia {
  INCAPACIDAD_IMSS
  VACACIONES
  PERMISO_CON_GOCE
  PERMISO_SIN_GOCE
  FALTA_JUSTIFICADA
  FALTA_INJUSTIFICADA
  OTRO
}

enum TipoGasto {
  COMBUSTIBLE
  CASETA
  VIATICOS
  OTRO
}

enum EstadoCartaPorte {
  BORRADOR
  PENDIENTE_TIMBRAR
  TIMBRADO
  CANCELADO
}

enum EstadoFactura {
  BORRADOR
  ENVIADA
  PAGADA
  VENCIDA
  CANCELADA
}

// ──────────────────────────── Catálogos ──────────────────────────

/// Catálogo genérico autoadministrable. Los campos de "tipo/categoría" del
/// sistema guardan el `codigo` de un item de su `grupo` (p. ej. grupo
/// 'TIPO_EXAMEN_MEDICO'). Los estados con lógica de negocio (EstadoViaje,
/// EstadoCartaPorte, EstadoFactura) siguen como enum. Los enums restantes
/// quedan como tipos legados sin uso; la fuente de verdad es esta tabla.
model CatalogoItem {
  id        String   @id @default(cuid())
  grupo     String   // p. ej. 'TIPO_EXAMEN_MEDICO', 'CATEGORIA_LICENCIA'
  codigo    String   // estable; es lo que se guarda en las demás tablas
  nombre    String   // etiqueta visible
  orden     Int      @default(0)
  color     String?  // variante de badge (success, destructive, secondary, outline…)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grupo, codigo])
  @@index([grupo])
  @@map("catalogo_items")
}

// ──────────────────────────── Usuarios ───────────────────────────

/// Admin del panel web (dueño de la flotilla). Una instancia = un admin (MVP).
model Usuario {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  nombre           String
  activo           Boolean  @default(true)
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("usuarios")
}

/// Conductor: credenciales separadas para la app Flutter.
/// Incluye los datos de RH del expediente formal (las secciones detalladas
/// viven en modelos relacionados: médico, certificaciones, incidencias, etc.).
model Conductor {
  id               String   @id @default(cuid())
  nombre           String
  apellidos        String?
  usuario          String   @unique // login de la app
  email            String?  @unique
  passwordHash     String
  telefono         String?
  fotoKey          String?  // objeto en MinIO
  refreshTokenHash String?
  activo           Boolean  @default(true)

  // ── Datos personales / RH (expediente) ──
  curp                String?            @unique
  rfc                 String?
  nss                 String?            // número de seguridad social (IMSS)
  fechaNacimiento     DateTime?
  tipoSangre          String?
  direccion           String?
  numeroEmpleado      String?            @unique
  puesto              String?
  fechaIngreso        DateTime?
  categoriaLicencia   String?            // catálogo CATEGORIA_LICENCIA
  // Contacto de emergencia
  emergenciaNombre    String?
  emergenciaTelefono  String?
  emergenciaRelacion  String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documentos        DocumentoConductor[]
  viajes            Viaje[]
  ubicaciones       UbicacionConductor[]
  // ── Secciones del expediente ──
  examenesMedicos   ExamenMedicoConductor[]
  certificaciones   CertificacionConductor[]
  capacitaciones    CapacitacionConductor[]
  incidencias       IncidenciaConductor[]
  eventosLaborales  EventoLaboralConductor[]
  aptitudesUnidad   AptitudUnidadConductor[]
  controlesConfianza ControlConfianzaConductor[]
  evaluaciones      EvaluacionDesempenoConductor[]
  ausencias         AusenciaConductor[]

  @@map("conductores")
}

// ───────────────────────────── Flota ─────────────────────────────

model Unidad {
  id            String   @id @default(cuid())
  placas        String   @unique
  tipo          String   // tractocamión, camión, camioneta, etc. (catálogo TIPO_UNIDAD)
  marca         String?
  modelo        String?
  anio          Int?
  capacidadKg   Decimal? @db.Decimal(10, 2)
  // Entradas del motor de cálculo (uso adecuado de la unidad):
  capacidadM3      Decimal? @db.Decimal(10, 3) // capacidad volumétrica
  rendimientoKmL   Decimal? @db.Decimal(6, 2)  // km por litro
  capacidadTanqueL Decimal? @db.Decimal(8, 2)  // litros de tanque (autonomía = rendimiento * tanque)
  aseguradora   String?
  numeroPoliza  String?
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  documentos DocumentoUnidad[]
  archivos   ArchivoUnidad[]
  viajes     Viaje[]

  @@map("unidades")
}

/// Categoría de un archivo adjunto a una unidad.
enum CategoriaArchivoUnidad {
  POLIZA_SEGURO
  GENERAL
}

/// Archivo adjunto a una unidad (póliza de seguro o documentos propios del
/// vehículo). Varios por unidad; el binario vive en MinIO bajo `key`.
model ArchivoUnidad {
  id          String                 @id @default(cuid())
  unidadId    String
  categoria   CategoriaArchivoUnidad @default(GENERAL)
  nombre      String // nombre original del archivo
  key         String // object key en MinIO
  contentType String
  tamanoBytes Int
  createdAt   DateTime               @default(now())

  unidad Unidad @relation(fields: [unidadId], references: [id], onDelete: Cascade)

  @@index([unidadId])
  @@index([unidadId, categoria])
  @@map("archivos_unidad")
}

model DocumentoUnidad {
  id              String              @id @default(cuid())
  unidadId        String
  tipo            String              // catálogo TIPO_DOCUMENTO_UNIDAD
  descripcion     String?
  fechaEmision    DateTime?
  fechaVencimiento DateTime
  archivoKey      String?             // objeto en MinIO
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  unidad Unidad @relation(fields: [unidadId], references: [id], onDelete: Cascade)

  @@index([unidadId])
  @@index([fechaVencimiento])
  @@map("documentos_unidad")
}

model DocumentoConductor {
  id              String                 @id @default(cuid())
  conductorId     String
  tipo            String                 // catálogo TIPO_DOCUMENTO_CONDUCTOR
  numero          String?
  fechaEmision    DateTime?
  fechaVencimiento DateTime
  archivoKey      String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@index([fechaVencimiento])
  @@map("documentos_conductor")
}

// ───────────────── Expediente del conductor ──────────────────────

/// Expediente médico y análisis continuo: cada examen periódico del conductor.
model ExamenMedicoConductor {
  id              String           @id @default(cuid())
  conductorId     String
  tipo            String           // catálogo TIPO_EXAMEN_MEDICO
  resultado       String           @default("PENDIENTE") // catálogo RESULTADO_EXAMEN
  fechaExamen     DateTime
  fechaVencimiento DateTime?       // p. ej. aptitud psicofísica vigente 2 años
  institucion     String?          // clínica / laboratorio
  medico          String?
  observaciones   String?
  archivoKey      String?          // dictamen en MinIO
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@index([fechaVencimiento])
  @@map("examenes_medicos_conductor")
}

/// Certificaciones formales (materiales peligrosos, manejo defensivo, etc.).
model CertificacionConductor {
  id              String            @id @default(cuid())
  conductorId     String
  tipo            String            // catálogo TIPO_CERTIFICACION
  nombre          String
  emisor          String?
  folio           String?
  fechaEmision    DateTime?
  fechaVencimiento DateTime?
  archivoKey      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@index([fechaVencimiento])
  @@map("certificaciones_conductor")
}

/// Capacitaciones / cursos tomados por el conductor.
model CapacitacionConductor {
  id            String    @id @default(cuid())
  conductorId   String
  nombre        String
  instructor    String?
  institucion   String?
  horas         Int?
  fechaInicio   DateTime?
  fechaFin      DateTime?
  aprobado      Boolean?
  calificacion  Decimal?  @db.Decimal(5, 2)
  constanciaKey String?   // constancia en MinIO
  notas         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@map("capacitaciones_conductor")
}

/// Incidencias: accidentes, infracciones, sanciones y reconocimientos.
model IncidenciaConductor {
  id            String             @id @default(cuid())
  conductorId   String
  viajeId       String?            // vínculo opcional al viaje donde ocurrió
  tipo          String             // catálogo TIPO_INCIDENCIA
  gravedad      String             @default("MEDIA") // catálogo GRAVEDAD_INCIDENCIA
  titulo        String
  descripcion   String?
  fecha         DateTime
  lugar         String?
  costoEstimado Decimal?           @db.Decimal(12, 2)
  resuelta      Boolean            @default(false)
  evidenciaKey  String?
  registradoPor String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)
  viaje     Viaje?    @relation(fields: [viajeId], references: [id], onDelete: SetNull)

  @@index([conductorId])
  @@index([viajeId])
  @@map("incidencias_conductor")
}

/// Progreso / trayectoria del conductor en la empresa (línea de tiempo).
model EventoLaboralConductor {
  id            String            @id @default(cuid())
  conductorId   String
  tipo          String            // catálogo TIPO_EVENTO_LABORAL
  titulo        String
  descripcion   String?
  puestoNuevo   String?
  fecha         DateTime
  registradoPor String?
  createdAt     DateTime          @default(now())

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@map("eventos_laborales_conductor")
}

/// Aptitud del conductor por tipo de unidad de transporte (manejo frecuente).
model AptitudUnidadConductor {
  id              String           @id @default(cuid())
  conductorId     String
  tipoUnidad      String           // catálogo TIPO_UNIDAD_MANEJO
  nivel           String           @default("INTERMEDIO") // catálogo NIVEL_APTITUD
  aniosExperiencia Int?
  notas           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@unique([conductorId, tipoUnidad])
  @@index([conductorId])
  @@map("aptitudes_unidad_conductor")
}

/// Control de confianza y antecedentes.
model ControlConfianzaConductor {
  id              String               @id @default(cuid())
  conductorId     String
  tipo            String               // catálogo TIPO_CONTROL_CONFIANZA
  resultado       String               @default("PENDIENTE") // catálogo RESULTADO_EXAMEN
  institucion     String?
  folio           String?
  fechaEvaluacion DateTime
  fechaVencimiento DateTime?
  observaciones   String?
  archivoKey      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@index([fechaVencimiento])
  @@map("controles_confianza_conductor")
}

/// Evaluación de desempeño con KPIs (puntualidad, consumo, telemetría).
model EvaluacionDesempenoConductor {
  id                String   @id @default(cuid())
  conductorId       String
  periodoInicio     DateTime
  periodoFin        DateTime
  // KPIs (0–100 salvo donde se indique)
  puntuacionGeneral Decimal? @db.Decimal(5, 2)
  puntualidad       Decimal? @db.Decimal(5, 2)
  consumoCombustible Decimal? @db.Decimal(6, 2) // km/L promedio
  cumplimientoRutas Decimal? @db.Decimal(5, 2)
  incidenciasPeriodo Int?
  viajesCompletados Int?
  comentarios       String?
  evaluadoPor       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@map("evaluaciones_desempeno_conductor")
}

/// Asistencias / incapacidades / vacaciones.
model AusenciaConductor {
  id            String       @id @default(cuid())
  conductorId   String
  tipo          String       // catálogo TIPO_AUSENCIA
  fechaInicio   DateTime
  fechaFin      DateTime?
  dias          Int?
  motivo        String?
  folioIncapacidad String?   // folio IMSS si aplica
  autorizadoPor String?
  documentoKey  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@map("ausencias_conductor")
}

// ──────────────────────── Clientes finales ───────────────────────

/// Cliente del transportista (a quien se le presta el servicio de viaje).
model Cliente {
  id               String   @id @default(cuid())
  razonSocial      String
  rfc              String?
  contactoNombre   String?
  contactoTelefono String?
  contactoEmail    String?
  direccion        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  viajes Viaje[]

  @@map("clientes")
}

// ───────────────────────────── Viajes ────────────────────────────

/// Aggregate root del dominio.
model Viaje {
  id            String      @id @default(cuid())
  folio         Int         @unique @default(autoincrement())
  clienteId     String
  unidadId      String?
  conductorId   String?

  // Origen / destino — DERIVADOS de las escalas (primera = origen, última = destino).
  // Se mantienen denormalizados para el tracking público, la búsqueda del listado y el mapa.
  origenDireccion  String
  origenLat        Float?
  origenLng        Float?
  destinoDireccion String
  destinoLat       Float?
  destinoLng       Float?

  // Carga — DERIVADA de las cargas de las escalas (resumen para listado/fiscal).
  tipoCarga        String
  descripcionCarga String?
  pesoKg           Decimal? @db.Decimal(10, 2)
  dimensiones      String?

  // Snapshot del motor de cálculo (se recalcula al crear/editar).
  distanciaEstimadaKm Decimal? @db.Decimal(10, 2)
  pesoMaxKg           Decimal? @db.Decimal(10, 2)
  volumenMaxM3        Decimal? @db.Decimal(10, 3)

  estado        EstadoViaje @default(ASIGNADO)
  trackingToken String      @unique // link público; token aleatorio seguro (ver token.util.ts)

  fechaProgramada DateTime?
  fechaInicio     DateTime?
  fechaEntrega    DateTime?
  odometroInicial Int?
  odometroFinal   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente   Cliente    @relation(fields: [clienteId], references: [id])
  unidad    Unidad?    @relation(fields: [unidadId], references: [id])
  conductor Conductor? @relation(fields: [conductorId], references: [id])

  escalas     EscalaViaje[]
  historial   HistorialEstadoViaje[]
  ubicaciones UbicacionConductor[]
  gastos      GastoViaje[]
  evidencias  EvidenciaViaje[]
  incidencias IncidenciaConductor[]
  cartaPorte  CartaPorte?
  factura     Factura?

  @@index([clienteId])
  @@index([unidadId])
  @@index([conductorId])
  // El listado filtra por estado y ordena por createdAt desc (índice compuesto);
  // fechaProgramada se usa en el filtro de rango; createdAt en el orden por defecto.
  @@index([estado, createdAt])
  @@index([fechaProgramada])
  @@index([createdAt])
  @@map("viajes")
}

model HistorialEstadoViaje {
  id             String       @id @default(cuid())
  viajeId        String
  estadoAnterior EstadoViaje?
  estadoNuevo    EstadoViaje
  nota           String?
  registradoPor  String?      // id de usuario o conductor
  createdAt      DateTime     @default(now())

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@map("historial_estado_viaje")
}

model UbicacionConductor {
  id          String   @id @default(cuid())
  viajeId     String
  conductorId String
  lat         Float
  lng         Float
  velocidad   Float?
  rumbo       Float?
  precision   Float?
  capturadoEn DateTime // timestamp del dispositivo
  createdAt   DateTime @default(now())

  viaje     Viaje     @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@index([viajeId, capturadoEn])
  @@map("ubicaciones_conductor")
}

model GastoViaje {
  id           String    @id @default(cuid())
  viajeId      String
  tipo         String    // catálogo TIPO_GASTO
  monto        Decimal   @db.Decimal(10, 2)
  descripcion  String?
  fotoTicketKey String?  // objeto en MinIO
  createdAt    DateTime  @default(now())

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@map("gastos_viaje")
}

/// POD — prueba de entrega.
model EvidenciaViaje {
  id            String   @id @default(cuid())
  viajeId       String
  fotoKey       String?  // foto de mercancía
  firmaKey      String?  // firma digital del receptor
  receptorNombre String?
  lat           Float?
  lng           Float?
  capturadoEn   DateTime
  createdAt     DateTime @default(now())

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@map("evidencias_viaje")
}

/// Escala (parada) del itinerario de un viaje. Origen = orden 0, destino = última.
model EscalaViaje {
  id           String    @id @default(cuid())
  viajeId      String
  orden        Int // posición 0-based en el itinerario
  accion       String // catálogo ACCION_ESCALA: RECOGER / ENTREGAR / RECOGER_ENTREGAR / PASO
  direccion    String
  lat          Float?
  lng          Float?
  // Columna geography GENERADA por SQL (ST_MakePoint) para consultas PostGIS;
  // la app escribe lat/lng, no esta columna. Se declara para que Prisma la conozca
  // (no genere drift/DROP); el ADD COLUMN se reemplaza por GENERATED en la migración.
  ubicacion    Unsupported("geography(Point, 4326)")?
  notas        String?
  ventanaDesde DateTime?
  ventanaHasta DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  viaje  Viaje         @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  cargas CargaEscala[]

  @@unique([viajeId, orden])
  @@index([viajeId])
  @@map("escalas_viaje")
}

/// Carga que se recoge o entrega en una escala. "Reemplazar" = DESCARGA + CARGA en
/// la misma escala; loteRef empareja una DESCARGA con la CARGA previa del mismo lote.
model CargaEscala {
  id          String   @id @default(cuid())
  escalaId    String
  sentido     String // catálogo SENTIDO_CARGA: CARGA / DESCARGA
  tipoCarga   String // catálogo TIPO_CARGA
  descripcion String?
  pesoKg      Decimal  @db.Decimal(10, 2)
  volumenM3   Decimal? @db.Decimal(10, 3)
  largoM      Decimal? @db.Decimal(8, 3)
  anchoM      Decimal? @db.Decimal(8, 3)
  altoM       Decimal? @db.Decimal(8, 3)
  cantidad    Int      @default(1)
  loteRef     String?
  createdAt   DateTime @default(now())

  escala EscalaViaje @relation(fields: [escalaId], references: [id], onDelete: Cascade)

  @@index([escalaId])
  @@map("cargas_escala")
}

/// Regla de compatibilidad tipo de carga ↔ tipo de unidad (la consume el motor).
model CompatibilidadCargaUnidad {
  id         String  @id @default(cuid())
  tipoCarga  String // catálogo TIPO_CARGA
  tipoUnidad String // catálogo TIPO_UNIDAD
  permitido  Boolean @default(true)
  nota       String?

  @@unique([tipoCarga, tipoUnidad])
  @@map("compatibilidad_carga_unidad")
}

// ──────────────────── Fiscal: Carta Porte / Factura (Fase 2) ───────

model CartaPorte {
  id            String           @id @default(cuid())
  viajeId       String           @unique
  estado        EstadoCartaPorte @default(BORRADOR)
  uuid          String?          // UUID del timbre (SAT)
  xmlKey        String?
  pdfKey        String?
  fechaTimbrado DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  viaje   Viaje    @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  factura Factura?

  @@map("cartas_porte")
}

model Factura {
  id              String        @id @default(cuid())
  viajeId         String        @unique
  cartaPorteId    String?       @unique
  folio           Int           @unique @default(autoincrement())
  estado          EstadoFactura @default(BORRADOR)
  subtotal        Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  moneda          String        @default("MXN")
  fechaEmision    DateTime?
  fechaVencimiento DateTime?
  fechaPago       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  viaje      Viaje       @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  cartaPorte CartaPorte? @relation(fields: [cartaPorteId], references: [id])

  @@map("facturas")
}
