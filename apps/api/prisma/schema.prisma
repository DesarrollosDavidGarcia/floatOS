/// Nivel de aptitud del conductor para un tipo de unidad.
enum NivelAptitud {
  PRINCIPIANTE
  INTERMEDIO
  EXPERTO
}

/// Tipo de unidad de transporte que el conductor maneja con frecuencia.
enum TipoUnidadManejo {
  TRACTOCAMION
  TORTON
  RABON
  THORTON
  CAMION_3_5
  CAMIONETA
  CAJA_SECA
  CAJA_REFRIGERADA
  PLATAFORMA
  TOLVA
  PIPA
  FULL
  OTRO
}

/// Tipo de evaluación de control de confianza.
enum TipoControlConfianza {
  EXAMEN_CONFIANZA
  ANTECEDENTES_NO_PENALES
  ESTUDIO_SOCIOECONOMICO
  POLIGRAFO
  TOXICOLOGICO
  OTRO
}

/// Tipo de ausencia/asistencia registrada.
enum TipoAusencia {
  INCAPACIDAD_IMSS
  VACACIONES
  PERMISO_CON_GOCE
  PERMISO_SIN_GOCE
  FALTA_JUSTIFICADA
  FALTA_INJUSTIFICADA
  OTRO
