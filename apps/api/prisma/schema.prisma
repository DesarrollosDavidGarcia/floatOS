enum TipoGasto {
  COMBUSTIBLE
  CASETA
  VIATICOS
  OTRO
}

enum EstadoCartaPorte {
  BORRADOR
  PENDIENTE_TIMBRAR
  TIMBRADO
  CANCELADO
}

enum EstadoFactura {
  BORRADOR
  ENVIADA
  PAGADA
  VENCIDA
  CANCELADA
}

// ──────────────────────────── Catálogos ──────────────────────────

/// Catálogo genérico autoadministrable. Los campos de "tipo/categoría" del
/// sistema guardan el `codigo` de un item de su `grupo` (p. ej. grupo
/// 'TIPO_EXAMEN_MEDICO'). Los estados con lógica de negocio (EstadoViaje,
/// EstadoCartaPorte, EstadoFactura) siguen como enum. Los enums restantes
/// quedan como tipos legados sin uso; la fuente de verdad es esta tabla.
model CatalogoItem {
  id        String   @id @default(cuid())
  grupo     String   // p. ej. 'TIPO_EXAMEN_MEDICO', 'CATEGORIA_LICENCIA'
  codigo    String   // estable; es lo que se guarda en las demás tablas
  nombre    String   // etiqueta visible
  orden     Int      @default(0)
  color     String?  // variante de badge (success, destructive, secondary, outline…)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grupo, codigo])
  @@index([grupo])
  @@map("catalogo_items")
}

// ──────────────────────────── Usuarios ───────────────────────────

/// Rol de un usuario del panel. ADMIN tiene acceso total; MONITORISTA solo
/// opera viajes (crear/editar/asignar), monitoreo en vivo y lectura de
/// clientes/flota.
enum RolUsuario {
  ADMIN
  MONITORISTA
}

/// Usuario del panel web. ADMIN (dueño de la flotilla) o MONITORISTA.
model Usuario {
  id               String     @id @default(cuid())
  email            String     @unique
  passwordHash     String
  nombre           String
  rol              RolUsuario @default(ADMIN)
  activo           Boolean    @default(true)
  refreshTokenHash String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@map("usuarios")
}

/// Configuración de la empresa transportista (emisor). Singleton: una sola fila
/// por instancia. Reúne datos generales/fiscales, domicilio fiscal, datos para
/// Carta Porte (permiso SCT, seguro) y credenciales de PAC/CSD para timbrado
/// (Fase 2). Los secretos (token/clave del PAC y contraseña del CSD) NUNCA se
/// exponen en las respuestas de la API (la capa de aplicación los enmascara).
model Empresa {
  id            String  @id @default(cuid())
  // Datos generales / fiscales del emisor
  razonSocial   String?
  rfc           String?
  regimenFiscal String? // catálogo REGIMEN_FISCAL (c_RegimenFiscal)
  telefono      String?
  email         String?
  logoKey       String? // logo en MinIO (para PDF / documentos)
  // Domicilio fiscal
  calle     String?
  numeroExt String?
  numeroInt String?
  colonia   String?
  cp        String?
  municipio String?
  estado    String?
  pais      String? @default("México")
  // Carta Porte — datos del emisor / autotransporte
  permisoSctTipo       String? // catálogo TIPO_PERMISO_SCT (c_TipoPermiso)
  permisoSctNumero     String?
  aseguradoraRespCivil String?
  polizaRespCivil      String?
  // PAC / timbrado (SW Sapien por defecto)
  pacProveedor String? @default("SW")
  pacAmbiente  String? @default("PRUEBAS") // PRUEBAS | PRODUCCION
  pacUsuario   String?
  pacToken     String? // secreto — no se expone
  pacPassword  String? // secreto — no se expone
  // Certificado de Sello Digital (CSD)
  csdNumero   String?
  csdCerKey   String? // .cer en MinIO
  csdKeyKey   String? // .key en MinIO
  csdPassword String? // secreto — no se expone

  // Tarifas por defecto para la cotización del bot (n8n). JSON con la forma de
  // ParamsCotizacion (tarifaBase, precioPorKm, precioPorKg, precioDiesel,
  // rendimientoKmL, casetas, maniobrasPorEscala, margenPct, aplicaIva,
  // aplicaRetencion). Si es null, el bot usa valores por defecto del código.
  tarifasCotizacion Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("empresa")
}

/// Conductor: credenciales separadas para la app Flutter.
/// Incluye los datos de RH del expediente formal (las secciones detalladas
/// viven en modelos relacionados: médico, certificaciones, incidencias, etc.).
model Conductor {
  id               String   @id @default(cuid())
  nombre           String
  apellidos        String?
  usuario          String   @unique // login de la app
  email            String?  @unique
  passwordHash     String
  telefono         String?
  fotoKey          String?  // objeto en MinIO
  refreshTokenHash String?
  activo           Boolean  @default(true)

  // ── Datos personales / RH (expediente) ──
  curp                String?            @unique
  rfc                 String?
  nss                 String?            // número de seguridad social (IMSS)
  fechaNacimiento     DateTime?
  tipoSangre          String?
  direccion           String?
  numeroEmpleado      String?            @unique
  puesto              String?
  fechaIngreso        DateTime?
  categoriaLicencia   String?            // catálogo CATEGORIA_LICENCIA
  // Contacto de emergencia
  emergenciaNombre    String?
  emergenciaTelefono  String?
  emergenciaRelacion  String?

  // ── Contratación (planta / freelance / terciarizado) ──
  tipoContratacion          String?   @default("PLANTA") // catálogo TIPO_CONTRATACION
  // Datos de la empresa que presta al conductor (solo terciarizado/externo)
  empresaProveedor          String?
  empresaProveedorRfc       String?
  proveedorContactoNombre   String?
  proveedorContactoTelefono String?
  // Vigencia del contrato temporal/externo (engancha alertas de vencimiento)
  vigenciaDesde             DateTime?
  vigenciaHasta             DateTime?
  notasContratacion         String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  documentos        DocumentoConductor[]
  viajes            Viaje[]
  ubicaciones       UbicacionConductor[]
  // ── Secciones del expediente ──
  examenesMedicos   ExamenMedicoConductor[]
  certificaciones   CertificacionConductor[]
  capacitaciones    CapacitacionConductor[]
  incidencias       IncidenciaConductor[]
  eventosLaborales  EventoLaboralConductor[]
  aptitudesUnidad   AptitudUnidadConductor[]
  controlesConfianza ControlConfianzaConductor[]
  evaluaciones      EvaluacionDesempenoConductor[]
  ausencias         AusenciaConductor[]
  archivosExpediente ArchivoExpediente[]

  @@map("conductores")
}

// ───────────────────────────── Flota ─────────────────────────────

model Unidad {
  id            String   @id @default(cuid())
  placas        String   @unique
  tipo          String   // tractocamión, camión, camioneta, etc. (catálogo TIPO_UNIDAD)
  marca         String?
  modelo        String?
  anio          Int?
  capacidadKg   Decimal? @db.Decimal(10, 2)
  // Entradas del motor de cálculo (uso adecuado de la unidad):
  capacidadM3      Decimal? @db.Decimal(10, 3) // capacidad volumétrica
  rendimientoKmL   Decimal? @db.Decimal(6, 2)  // km por litro
  capacidadTanqueL Decimal? @db.Decimal(8, 2)  // litros de tanque (autonomía = rendimiento * tanque)
  aseguradora   String?
  numeroPoliza  String?
  fotoKey       String?  // foto de referencia del vehículo (objeto en MinIO)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  documentos DocumentoUnidad[]
  archivos   ArchivoUnidad[]
  viajes     Viaje[]

  @@map("unidades")
}

/// Caja / remolque intercambiable. El tractor (Unidad) tira de la caja; una caja
/// puede ir con distintos tractores y se puede cambiar a media operación (p. ej.
/// tras un choque) sin cambiar el tractor.
model Caja {
  id           String   @id @default(cuid())
  placas       String   @unique
  tipo         String // catálogo TIPO_CAJA (seca, refrigerada, etc.)
  marca        String?
  anio         Int?
  capacidadKg  Decimal? @db.Decimal(10, 2)
  capacidadM3  Decimal? @db.Decimal(10, 3)
  aseguradora  String?
  numeroPoliza String?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  viajes Viaje[]

  @@map("cajas")
}

/// Categoría de un archivo adjunto a una unidad.
enum CategoriaArchivoUnidad {
  POLIZA_SEGURO
  GENERAL
}

/// Archivo adjunto a una unidad (póliza de seguro o documentos propios del
/// vehículo). Varios por unidad; el binario vive en MinIO bajo `key`.
model ArchivoUnidad {
  id          String                 @id @default(cuid())
  unidadId    String
  categoria   CategoriaArchivoUnidad @default(GENERAL)
  nombre      String // nombre original del archivo
  key         String // object key en MinIO
  contentType String
  tamanoBytes Int
  createdAt   DateTime               @default(now())

  unidad Unidad @relation(fields: [unidadId], references: [id], onDelete: Cascade)

  @@index([unidadId])
  @@index([unidadId, categoria])
  @@map("archivos_unidad")
}

model DocumentoUnidad {
  id              String              @id @default(cuid())
  unidadId        String
  tipo            String              // catálogo TIPO_DOCUMENTO_UNIDAD
  descripcion     String?
  fechaEmision    DateTime?
  fechaVencimiento DateTime
  archivoKey      String?             // objeto en MinIO
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  unidad Unidad @relation(fields: [unidadId], references: [id], onDelete: Cascade)

  @@index([unidadId])
  @@index([fechaVencimiento])
  @@map("documentos_unidad")
}

model DocumentoConductor {
  id              String                 @id @default(cuid())
  conductorId     String
  tipo            String                 // catálogo TIPO_DOCUMENTO_CONDUCTOR
  numero          String?
  fechaEmision    DateTime?
  fechaVencimiento DateTime
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  conductor Conductor                     @relation(fields: [conductorId], references: [id], onDelete: Cascade)
  archivos  ArchivoDocumentoConductor[]

  @@index([conductorId])
  @@index([fechaVencimiento])
  @@map("documentos_conductor")
}

/// Archivo adjunto a un documento del conductor (PDF o imagen). N por documento.
model ArchivoDocumentoConductor {
  id          String   @id @default(cuid())
  documentoId String
  nombre      String // nombre original del archivo
  key         String // object key en MinIO
  contentType String
  tamanoBytes Int
  createdAt   DateTime @default(now())

  documento DocumentoConductor @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@index([documentoId])
  @@map("archivos_documento_conductor")
}

// ───────────────── Expediente del conductor ──────────────────────

/// Expediente médico y análisis continuo: cada examen periódico del conductor.
model ExamenMedicoConductor {
  id              String           @id @default(cuid())
  conductorId     String
  tipo            String           // catálogo TIPO_EXAMEN_MEDICO
  resultado       String           @default("PENDIENTE") // catálogo RESULTADO_EXAMEN
  fechaExamen     DateTime
  fechaVencimiento DateTime?       // p. ej. aptitud psicofísica vigente 2 años
  institucion     String?          // clínica / laboratorio
  medico          String?
  observaciones   String?
  archivoKey      String?          // dictamen en MinIO
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@index([fechaVencimiento])
  @@map("examenes_medicos_conductor")
}

/// Certificaciones formales (materiales peligrosos, manejo defensivo, etc.).
model CertificacionConductor {
  id              String            @id @default(cuid())
  conductorId     String
  tipo            String            // catálogo TIPO_CERTIFICACION
  nombre          String
  emisor          String?
  folio           String?
  fechaEmision    DateTime?
  fechaVencimiento DateTime?
  archivoKey      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@index([fechaVencimiento])
  @@map("certificaciones_conductor")
}

/// Capacitaciones / cursos tomados por el conductor.
model CapacitacionConductor {
  id            String    @id @default(cuid())
  conductorId   String
  nombre        String
  instructor    String?
  institucion   String?
  horas         Int?
  fechaInicio   DateTime?
  fechaFin      DateTime?
  aprobado      Boolean?
  calificacion  Decimal?  @db.Decimal(5, 2)
  constanciaKey String?   // constancia en MinIO
  notas         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@map("capacitaciones_conductor")
}

/// Incidencias: accidentes, infracciones, sanciones y reconocimientos.
model IncidenciaConductor {
  id            String             @id @default(cuid())
  conductorId   String
  viajeId       String?            // vínculo opcional al viaje donde ocurrió
  tipo          String             // catálogo TIPO_INCIDENCIA
  gravedad      String             @default("MEDIA") // catálogo GRAVEDAD_INCIDENCIA
  titulo        String
  descripcion   String?
  fecha         DateTime
  lugar         String?
  costoEstimado Decimal?           @db.Decimal(12, 2)
  resuelta      Boolean            @default(false)
  evidenciaKey  String?
  registradoPor String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)
  viaje     Viaje?    @relation(fields: [viajeId], references: [id], onDelete: SetNull)

  @@index([conductorId])
  @@index([viajeId])
  @@map("incidencias_conductor")
}

/// Progreso / trayectoria del conductor en la empresa (línea de tiempo).
model EventoLaboralConductor {
  id            String            @id @default(cuid())
  conductorId   String
  tipo          String            // catálogo TIPO_EVENTO_LABORAL
  titulo        String
  descripcion   String?
  puestoNuevo   String?
  fecha         DateTime
  registradoPor String?
  createdAt     DateTime          @default(now())

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@map("eventos_laborales_conductor")
}

/// Aptitud del conductor por tipo de unidad de transporte (manejo frecuente).
model AptitudUnidadConductor {
  id              String           @id @default(cuid())
  conductorId     String
  tipoUnidad      String           // catálogo TIPO_UNIDAD_MANEJO
  nivel           String           @default("INTERMEDIO") // catálogo NIVEL_APTITUD
  aniosExperiencia Int?
  notas           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@unique([conductorId, tipoUnidad])
  @@index([conductorId])
  @@map("aptitudes_unidad_conductor")
}

/// Control de confianza y antecedentes.
model ControlConfianzaConductor {
  id              String               @id @default(cuid())
  conductorId     String
  tipo            String               // catálogo TIPO_CONTROL_CONFIANZA
  resultado       String               @default("PENDIENTE") // catálogo RESULTADO_EXAMEN
  institucion     String?
  folio           String?
  fechaEvaluacion DateTime
  fechaVencimiento DateTime?
  observaciones   String?
  archivoKey      String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@index([fechaVencimiento])
  @@map("controles_confianza_conductor")
}

/// Evaluación de desempeño con KPIs (puntualidad, consumo, telemetría).
model EvaluacionDesempenoConductor {
  id                String   @id @default(cuid())
  conductorId       String
  periodoInicio     DateTime
  periodoFin        DateTime
  // KPIs (0–100 salvo donde se indique)
  puntuacionGeneral Decimal? @db.Decimal(5, 2)
  puntualidad       Decimal? @db.Decimal(5, 2)
  consumoCombustible Decimal? @db.Decimal(6, 2) // km/L promedio
  cumplimientoRutas Decimal? @db.Decimal(5, 2)
  incidenciasPeriodo Int?
  viajesCompletados Int?
  comentarios       String?
  evaluadoPor       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@map("evaluaciones_desempeno_conductor")
}

/// Asistencias / incapacidades / vacaciones.
model AusenciaConductor {
  id            String       @id @default(cuid())
  conductorId   String
  tipo          String       // catálogo TIPO_AUSENCIA
  fechaInicio   DateTime
  fechaFin      DateTime?
  dias          Int?
  motivo        String?
  folioIncapacidad String?   // folio IMSS si aplica
  autorizadoPor String?
  documentoKey  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@map("ausencias_conductor")
}

/// Sección del expediente a la que pertenece un archivo de evidencia.
enum SeccionExpediente {
  EXAMEN_MEDICO
  CERTIFICACION
  CAPACITACION
  CONTROL_CONFIANZA
  INCIDENCIA
  EVALUACION
}

/// Archivo de evidencia (PDF o imagen) adjunto a un registro de una sección del
/// expediente del conductor (médico, certificación, capacitación, control de
/// confianza, incidencia o evaluación). N por registro; el binario vive en MinIO
/// bajo `key`. `registroId` apunta al id del registro de su `seccion`; el FK a
/// Conductor garantiza el cascade al borrar el conductor (el borrado de un
/// registro individual limpia sus archivos en la capa de aplicación).
model ArchivoExpediente {
  id          String            @id @default(cuid())
  conductorId String
  seccion     SeccionExpediente
  registroId  String
  nombre      String // nombre original del archivo
  key         String // object key en MinIO
  contentType String
  tamanoBytes Int
  createdAt   DateTime          @default(now())

  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([conductorId])
  @@index([seccion, registroId])
  @@map("archivos_expediente")
}

// ──────────────────────── Clientes finales ───────────────────────

/// Cliente del transportista (a quien se le presta el servicio de viaje).
// razonSocial se busca con ILIKE '%x%' desde el listado de viajes (join cliente):
// índice GIN trigram (pg_trgm) creado por SQL crudo en la migración
// 20260624130000_busqueda_trigram_viajes (no como @@index; ver modelo Viaje).
model Cliente {
  id               String   @id @default(cuid())
  razonSocial      String
  rfc              String?
  // Datos fiscales (CFDI 4.0) — códigos de catálogo SAT (grupos REGIMEN_FISCAL / USO_CFDI).
  regimenFiscal    String?
  usoCfdi          String?
  cpFiscal         String?
  emailFacturacion String?
  direccion        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  contactos  ContactoCliente[]
  sucursales SucursalCliente[]
  viajes     Viaje[]

  @@map("clientes")
}

/// Sucursal (domicilio adicional) de un cliente: punto de recolección/entrega.
/// Un cliente puede tener varias. Sirve como origen/destino de viajes y como
/// domicilio del receptor en Carta Porte.
model SucursalCliente {
  id        String  @id @default(cuid())
  clienteId String
  nombre    String
  rfc       String? // normalmente el del cliente
  // Domicilio
  calle     String?
  numeroExt String?
  numeroInt String?
  colonia   String?
  cp        String?
  municipio String?
  estado    String?
  pais      String? @default("México")
  lat       Float?
  lng       Float?
  esPrincipal Boolean @default(false)
  orden       Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("sucursales_cliente")
}

/// Contacto del cliente (lista). Uno puede marcarse como principal: es el
/// destinatario por defecto al cotizar/enviar correo. Si ninguno lo está, se
/// usa el de menor `orden`.
model ContactoCliente {
  id          String   @id @default(cuid())
  clienteId   String
  nombre      String
  email       String?
  telefono    String? // celular
  esPrincipal Boolean  @default(false)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("contactos_cliente")
}

// ───────────────────────────── Viajes ────────────────────────────

/// Aggregate root del dominio.
// Búsqueda del listado (ILIKE '%x%' sobre origenDireccion, destinoDireccion,
// tipoCarga, descripcionCarga): acelerada por índices GIN trigram (pg_trgm) que
// se crean por SQL crudo (migración 20260624130000_busqueda_trigram_viajes), NO
// como @@index aquí — Prisma generaría un btree, inútil para patrones no anclados.
model Viaje {
  id            String      @id @default(cuid())
  folio         Int         @unique @default(autoincrement())
  clienteId     String
  unidadId      String? // tractor
  cajaId        String? // caja / remolque (intercambiable)
  conductorId   String?

  // Origen / destino — DERIVADOS de las escalas (primera = origen, última = destino).
  // Se mantienen denormalizados para el tracking público, la búsqueda del listado y el mapa.
  origenDireccion  String
  origenLat        Float?
  origenLng        Float?
  destinoDireccion String
  destinoLat       Float?
  destinoLng       Float?

  // Carga — DERIVADA de las cargas de las escalas (resumen para listado/fiscal).
  tipoCarga        String
  descripcionCarga String?
  pesoKg           Decimal? @db.Decimal(10, 2)
  dimensiones      String?

  // Snapshot del motor de cálculo (se recalcula al crear/editar).
  distanciaEstimadaKm Decimal? @db.Decimal(10, 2)
  // ETA estimada por carretera (free-flow, sin tráfico en vivo); null si geodésica.
  tiempoEstimadoMin   Float?
  pesoMaxKg           Decimal? @db.Decimal(10, 2)
  volumenMaxM3        Decimal? @db.Decimal(10, 3)
  // Polilínea de la ruta por carretera ([[lat, lng], ...]) para pintar el mapa;
  // null si se calculó por geodésica (el mapa cae a líneas rectas entre escalas).
  rutaGeometria       Json?
  // Plan multi-día que asigna el monitorista (horas de conducción/día, descanso,
  // tiempo por escala, hora de inicio). Alimenta el cálculo de llegada estimada.
  planRuta            Json?

  estado        EstadoViaje @default(ASIGNADO)
  // Estado al que regresar al reanudar tras VARADO (null si no está/estuvo varado).
  estadoPrevioVarado EstadoViaje?
  trackingToken String      @unique // link público; token aleatorio seguro (ver token.util.ts)

  fechaProgramada DateTime?
  fechaInicio     DateTime?
  fechaEntrega    DateTime?
  odometroInicial Int?
  odometroFinal   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente   Cliente    @relation(fields: [clienteId], references: [id])
  unidad    Unidad?    @relation(fields: [unidadId], references: [id])
  caja      Caja?      @relation(fields: [cajaId], references: [id])
  conductor Conductor? @relation(fields: [conductorId], references: [id])

  escalas               EscalaViaje[]
  historial             HistorialEstadoViaje[]
  historialAsignaciones HistorialAsignacionViaje[]
  ubicaciones UbicacionConductor[]
  gastos      GastoViaje[]
  evidencias  EvidenciaViaje[]
  incidencias IncidenciaConductor[]
  cartaPorte   CartaPorte?
  factura      Factura?
  cotizaciones Cotizacion[]
  mensajesChat MensajeChat[]

  @@index([clienteId])
  @@index([unidadId])
  @@index([cajaId])
  @@index([conductorId])
  // El listado filtra por estado y ordena por createdAt desc (índice compuesto);
  // fechaProgramada se usa en el filtro de rango; createdAt en el orden por defecto.
  @@index([estado, createdAt])
  @@index([fechaProgramada])
  @@index([createdAt])
  @@map("viajes")
}

/// Quién envió un mensaje de chat: un usuario del panel (monitorista/admin) o el
/// conductor del viaje.
enum AutorMensaje {
  MONITORISTA
  CONDUCTOR
}

/// Mensaje del chat de un viaje (comunicación bidireccional monitorista↔conductor).
/// Texto y/o un adjunto (imagen o PDF en MinIO). Los flags de lectura son por
/// "lado" (no por usuario): se marca leído cuando el panel o el conductor abren
/// el chat del viaje.
model MensajeChat {
  id          String       @id @default(cuid())
  viajeId     String
  autorTipo   AutorMensaje
  // Emisor concreto: usuarioId si autorTipo=MONITORISTA, conductorId si CONDUCTOR.
  usuarioId   String?
  conductorId String?
  autorNombre String // nombre mostrado (snapshot al enviar)
  texto       String? // puede ser null si el mensaje es solo un adjunto

  // Adjunto opcional (imagen/PDF en MinIO).
  archivoKey    String?
  archivoNombre String?
  archivoTipo   String? // mimetype
  archivoBytes  Int?

  // Lectura por lado (no por usuario): el panel marca leídos los del conductor y
  // viceversa. Sirve para el contador de no leídos.
  leidoMonitorista Boolean @default(false)
  leidoConductor   Boolean @default(false)

  createdAt DateTime @default(now())

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId, createdAt])
  // Aceleran el conteo de no leídos por lado (panel vs conductor).
  @@index([autorTipo, leidoMonitorista])
  @@index([autorTipo, leidoConductor])
  @@map("mensajes_chat")
}

model HistorialEstadoViaje {
  id             String       @id @default(cuid())
  viajeId        String
  estadoAnterior EstadoViaje?
  estadoNuevo    EstadoViaje
  nota           String?
  registradoPor  String?      // id de usuario o conductor
  createdAt      DateTime     @default(now())

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@map("historial_estado_viaje")
}

/// Auditoría de reasignaciones (cambio de unidad y/o conductor) de un viaje.
/// Guarda etiquetas legibles (placas/nombre) para que el historial sobreviva a
/// la baja de una unidad o conductor. Un campo null = esa dimensión no cambió.
model HistorialAsignacionViaje {
  id                String   @id @default(cuid())
  viajeId           String
  unidadAnterior    String? // placas previas (o "Sin unidad")
  unidadNueva       String?
  cajaAnterior      String? // placas de caja previas (o "Sin caja")
  cajaNueva         String?
  conductorAnterior String? // nombre previo (o "Sin conductor")
  conductorNuevo    String?
  motivo            String? // catálogo MOTIVOS_REASIGNACION (o libre)
  nota              String?
  registradoPor     String? // id de usuario admin
  createdAt         DateTime @default(now())

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@map("historial_asignacion_viaje")
}

model UbicacionConductor {
  id          String   @id @default(cuid())
  viajeId     String
  conductorId String
  lat         Float
  lng         Float
  velocidad   Float?
  rumbo       Float?
  precision   Float?
  capturadoEn DateTime // timestamp del dispositivo
  createdAt   DateTime @default(now())

  viaje     Viaje     @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  conductor Conductor @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@index([viajeId, capturadoEn])
  @@map("ubicaciones_conductor")
}

model GastoViaje {
  id           String    @id @default(cuid())
  viajeId      String
  tipo         String    // catálogo TIPO_GASTO
  monto        Decimal   @db.Decimal(10, 2)
  descripcion  String?
  fotoTicketKey String?  // objeto en MinIO
  createdAt    DateTime  @default(now())

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@map("gastos_viaje")
}

/// POD — prueba de entrega.
model EvidenciaViaje {
  id            String   @id @default(cuid())
  viajeId       String
  fotoKey       String?  // foto de mercancía
  firmaKey      String?  // firma digital del receptor
  receptorNombre String?
  lat           Float?
  lng           Float?
  capturadoEn   DateTime
  createdAt     DateTime @default(now())

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@map("evidencias_viaje")
}

/// Escala (parada) del itinerario de un viaje. Origen = orden 0, destino = última.
model EscalaViaje {
  id           String    @id @default(cuid())
  viajeId      String
  orden        Int // posición 0-based en el itinerario
  accion       String // catálogo ACCION_ESCALA: RECOGER / ENTREGAR / RECOGER_ENTREGAR / PASO
  direccion    String
  lat          Float?
  lng          Float?
  // Columna geography GENERADA por SQL (ST_MakePoint) para consultas PostGIS;
  // la app escribe lat/lng, no esta columna. Se declara para que Prisma la conozca
  // (no genere drift/DROP); el ADD COLUMN se reemplaza por GENERATED en la migración.
  ubicacion    Unsupported("geography(Point, 4326)")?
  notas        String?
  ventanaDesde DateTime?
  ventanaHasta DateTime?
  // Marca de tiempo de la primera alerta de geocerca emitida (dedup entre lotes).
  llegadaNotificadaEn DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  viaje     Viaje            @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  cargas    CargaEscala[]
  contactos ContactoEscala[]

  @@unique([viajeId, orden])
  @@index([viajeId])
  @@map("escalas_viaje")
}

/// Persona a cargo en una escala: recibe el aviso de llegada del transportista.
/// Solo se gestiona cuando el viaje tiene una cotización ACEPTADA. Por ahora el
/// único canal de aviso es el email; el teléfono se guarda para un SMS futuro.
model ContactoEscala {
  id           String    @id @default(cuid())
  escalaId     String
  nombre       String
  email        String? // destinatario del aviso de llegada (único canal actual)
  telefono     String? // se captura/guarda; SMS pendiente de una fase futura
  // Sello del email de llegada enviado (registro y dedup por contacto).
  notificadoEn DateTime?
  createdAt    DateTime  @default(now())

  escala EscalaViaje @relation(fields: [escalaId], references: [id], onDelete: Cascade)

  @@index([escalaId])
  @@map("contactos_escala")
}

/// Carga que se recoge o entrega en una escala. "Reemplazar" = DESCARGA + CARGA en
/// la misma escala; loteRef empareja una DESCARGA con la CARGA previa del mismo lote.
model CargaEscala {
  id          String   @id @default(cuid())
  escalaId    String
  sentido     String // catálogo SENTIDO_CARGA: CARGA / DESCARGA
  tipoCarga   String // catálogo TIPO_CARGA
  descripcion String?
  pesoKg      Decimal  @db.Decimal(10, 2)
  volumenM3   Decimal? @db.Decimal(10, 3)
  largoM      Decimal? @db.Decimal(8, 3)
  anchoM      Decimal? @db.Decimal(8, 3)
  altoM       Decimal? @db.Decimal(8, 3)
  cantidad    Int      @default(1)
  loteRef     String?
  createdAt   DateTime @default(now())

  escala EscalaViaje @relation(fields: [escalaId], references: [id], onDelete: Cascade)

  @@index([escalaId])
  @@map("cargas_escala")
}

/// Regla de compatibilidad tipo de carga ↔ tipo de unidad (la consume el motor).
model CompatibilidadCargaUnidad {
  id         String  @id @default(cuid())
  tipoCarga  String // catálogo TIPO_CARGA
  tipoUnidad String // catálogo TIPO_UNIDAD
  permitido  Boolean @default(true)
  nota       String?

  @@unique([tipoCarga, tipoUnidad])
  @@map("compatibilidad_carga_unidad")
}

// ──────────────────── Fiscal: Carta Porte / Factura (Fase 2) ───────

model CartaPorte {
  id            String           @id @default(cuid())
  viajeId       String           @unique
  estado        EstadoCartaPorte @default(BORRADOR)
  uuid          String?          // UUID del timbre (SAT)
  xmlKey        String?
  pdfKey        String?
  fechaTimbrado DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  viaje   Viaje    @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  factura Factura?

  @@map("cartas_porte")
}

model Factura {
  id              String        @id @default(cuid())
  viajeId         String        @unique
  cartaPorteId    String?       @unique
  folio           Int           @unique @default(autoincrement())
  estado          EstadoFactura @default(BORRADOR)
  subtotal        Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  moneda          String        @default("MXN")
  fechaEmision    DateTime?
  fechaVencimiento DateTime?
  fechaPago       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  viaje      Viaje       @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  cartaPorte CartaPorte? @relation(fields: [cartaPorteId], references: [id])

  @@map("facturas")
}

// ──────────────────────── Cotizaciones ────────────────────────────

enum EstadoCotizacion {
  BORRADOR
  ENVIADA
  ACEPTADA
  RECHAZADA
}

/// Cotización de un viaje. Congela los parámetros capturados (params), los datos
/// del viaje usados y el desglose calculado por el motor (domain/cotizacion).
model Cotizacion {
  id          String           @id @default(cuid())
  folio       Int              @unique @default(autoincrement())
  viajeId     String
  estado      EstadoCotizacion @default(BORRADOR)
  moneda      String           @default("MXN")
  // Parámetros (tarifas) y datos del viaje usados, congelados.
  params      Json
  distanciaKm Decimal?         @db.Decimal(10, 2)
  pesoKg      Decimal?         @db.Decimal(10, 2)
  numEscalas  Int              @default(0)
  // Resultado del motor (líneas + subtotales) y totales para consulta rápida.
  desglose    Json
  subtotal    Decimal          @db.Decimal(12, 2)
  iva         Decimal          @db.Decimal(12, 2)
  retencion   Decimal          @db.Decimal(12, 2)
  total       Decimal          @db.Decimal(12, 2)
  notas       String?
  // Marca de tiempo del envío por correo (Fase 3, Brevo).
  enviadaEn   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  viaje Viaje @relation(fields: [viajeId], references: [id], onDelete: Cascade)

  @@index([viajeId])
  @@map("cotizaciones")
}

// ──────────────────── Caché de ruteo (TomTom) ─────────────────────

/// Caché persistente de rutas calculadas por el proveedor externo (TomTom) para
/// no repetir llamadas. `clave` es un hash determinista de las coordenadas
/// ordenadas + perfil (ver routing/route-provider.ts). Las rutas son estables en
/// el tiempo (traffic=false), así que se reutilizan entre viajes a largo plazo.
model RutaCache {
  id          String   @id @default(cuid())
  clave       String   @unique
  distanciaKm Float
  tiempoMin   Float?
  // Polilínea de la ruta por carretera ([[lat, lng], ...]); null si no se obtuvo.
  geometria   Json?
  proveedor   String // TOMTOM
  createdAt   DateTime @default(now())

  // Índice para la poda por antigüedad (purgarAntiguas en RouteService).
  @@index([createdAt])
  @@map("ruta_cache")
}
