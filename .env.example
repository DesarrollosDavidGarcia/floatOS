NODE_ENV=production
API_URL=https://api.cliente.tudominio.com

# --- Despliegue / imágenes ---
# Versión publicada que corre esta instancia (= git tag = tag de imagen).
# Los scripts de actualización editan este valor y hacen `docker compose pull`.
FLOTAOS_VERSION=latest
# Registry donde viven las imágenes (sin el nombre flotaos-api/flotaos-web).
IMAGE_REGISTRY=ghcr.io/desarrollosdavidgarcia

# Puertos públicos del host (solo en modo standalone, sin Traefik; cámbialos por
# cliente si comparten VPS).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Modo Traefik (producción multi-cliente con HTTPS por subdominio). Solo se usan
# con docker-compose.traefik.yml; en standalone se ignoran.
CLIENT_DOMAIN=cliente-xyz.tudominio.com
CLIENT_NAME=cliente-xyz

# --- Admin inicial (solo lo usa el script de alta de instancia) ---
ADMIN_EMAIL=admin@cliente.com
ADMIN_PASSWORD=CAMBIAR_EN_ALTA
ADMIN_NOMBRE=Administrador

# --- Database ---
POSTGRES_DB=flotaos
POSTGRES_USER=flotaos_user
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION
DATABASE_URL=postgresql://flotaos_user:CAMBIAR_EN_PRODUCCION@postgres:5432/flotaos?schema=public

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Auth ---
JWT_SECRET=CAMBIAR_MIN_32_CARACTERES_aaaaaaaaaaaa
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=CAMBIAR_OTRO_SECRET_MIN_32_CARACTERES
JWT_REFRESH_TTL=2592000

# --- MinIO (S3 compatible) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CAMBIAR_EN_PRODUCCION
MINIO_SECRET_KEY=CAMBIAR_EN_PRODUCCION
MINIO_BUCKET=flotaos

# --- PAC (Carta Porte CFDI 4.0) — Fase 2 ---
PAC_API_URL=https://api.facturama.mx
PAC_API_KEY=CLAVE_PAC

# --- WhatsApp Business API — Fase 2 ---
WHATSAPP_TOKEN=TOKEN_META
WHATSAPP_PHONE_ID=ID_NUMERO

# --- Datos del emisor (transportista) para documentos: cotización PDF, etc. ---
EMPRESA_NOMBRE=Mi Empresa de Transportes SA de CV
EMPRESA_RFC=XAXX010101000
EMPRESA_DIRECCION=Calle Falsa 123, Col. Centro, CDMX
EMPRESA_TELEFONO=55-1234-5678
EMPRESA_EMAIL=contacto@empresa.com

# --- Ruteo por carretera (TomTom) — opcional ---
# Key POR CLIENTE (una "Application" por instancia en el portal de TomTom). Solo
# se usa server-side; NUNCA se expone al navegador. Sin key, el motor cae a
# distancia geodésica (línea recta) con PostGIS. La key la inyecta alta-cliente.sh.
TOMTOM_API_KEY=
# Tope defensivo de llamadas/día (free tier = 2500/día por key). Default: 2000.
TOMTOM_MAX_DIARIO=2000

# --- SMTP (Nodemailer) ---
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_USER=alertas@tudominio.com
SMTP_PASSWORD=CAMBIAR
SMTP_FROM="FlotaOS <alertas@tudominio.com>"

# --- Correo: proveedor y remitente ---
# EmailService elige Brevo si hay BREVO_API_KEY; si no, usa SMTP (arriba).
EMAIL_FROM="FlotaOS <no-reply@tudominio.com>"
# --- Brevo (API transaccional) — opcional ---
BREVO_API_KEY=
# Remitente verificado en Brevo (obligatorio si usas Brevo).
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# --- Web (Next.js) ---
# NOTA: en producción la URL de API/WS se hornea en build como ruta relativa
# (ver docker-compose.build.yml), así que NO se configura aquí. Para correr el
# panel en desarrollo se usa apps/web/.env.local.
