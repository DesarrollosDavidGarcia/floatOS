NODE_ENV=production
API_URL=https://api.cliente.tudominio.com

# --- Despliegue / imágenes ---
# Versión publicada que corre esta instancia (= git tag = tag de imagen).
# Los scripts de actualización editan este valor y hacen `docker compose pull`.
FLOTAOS_VERSION=latest
# Registry donde viven las imágenes (sin el nombre flotaos-api/flotaos-web).
IMAGE_REGISTRY=ghcr.io/desarrollosdavidgarcia

# Puertos públicos del host (solo en modo standalone, sin Traefik; cámbialos por
# cliente si comparten VPS).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Modo Traefik (producción multi-cliente con HTTPS por subdominio). Solo se usan
# con docker-compose.traefik.yml; en standalone se ignoran.
CLIENT_DOMAIN=cliente-xyz.tudominio.com
CLIENT_NAME=cliente-xyz

# --- Admin inicial (solo lo usa el script de alta de instancia) ---
ADMIN_EMAIL=admin@cliente.com
ADMIN_PASSWORD=CAMBIAR_EN_ALTA
ADMIN_NOMBRE=Administrador

# --- Database ---
POSTGRES_DB=flotaos
POSTGRES_USER=flotaos_user
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION
DATABASE_URL=postgresql://flotaos_user:CAMBIAR_EN_PRODUCCION@postgres:5432/flotaos?schema=public

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Auth ---
JWT_SECRET=CAMBIAR_MIN_32_CARACTERES_aaaaaaaaaaaa
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=CAMBIAR_OTRO_SECRET_MIN_32_CARACTERES
JWT_REFRESH_TTL=2592000

# Llave para cifrar secretos en reposo (token/contraseña del PAC, contraseña del
# CSD) con AES-256-GCM. Usa una cadena larga y aleatoria, ÚNICA POR INSTANCIA.
# Si se deja vacía, se deriva de JWT_SECRET (no recomendado en producción).
# No la rotes sin volver a capturar los secretos (quedarían indescifrables).
SECRETS_KEY=CAMBIAR_LLAVE_ALEATORIA_LARGA_POR_INSTANCIA

# --- MinIO (S3 compatible) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CAMBIAR_EN_PRODUCCION
MINIO_SECRET_KEY=CAMBIAR_EN_PRODUCCION
MINIO_BUCKET=flotaos

# --- PAC (Carta Porte CFDI 4.0) — Fase 2 ---
PAC_API_URL=https://api.facturama.mx
PAC_API_KEY=CLAVE_PAC

# --- WhatsApp Business API — Fase 2 ---
WHATSAPP_TOKEN=TOKEN_META
WHATSAPP_PHONE_ID=ID_NUMERO

# --- Datos del emisor (transportista) para documentos: cotización PDF, etc. ---
EMPRESA_NOMBRE=Mi Empresa de Transportes SA de CV
EMPRESA_RFC=XAXX010101000
EMPRESA_DIRECCION=Calle Falsa 123, Col. Centro, CDMX
EMPRESA_TELEFONO=55-1234-5678
EMPRESA_EMAIL=contacto@empresa.com

# --- Ruteo por carretera — opcional ---
# Proveedor activo de ruteo por carretera: `tomtom` (default) | `google`.
# Reversible sin redeploy; sin key del proveedor elegido, el motor cae a
# distancia geodésica (línea recta) con PostGIS.
ROUTING_PROVIDER=tomtom

# TomTom: key POR CLIENTE (una "Application" por instancia en el portal de TomTom).
# Solo server-side; NUNCA se expone al navegador. La key la inyecta alta-cliente.sh.
TOMTOM_API_KEY=
# Tope defensivo de llamadas/día (free tier = 2500/día por key). Default: 2000.
TOMTOM_MAX_DIARIO=2000

# Google Routes API (cuando ROUTING_PROVIDER=google). Key de SERVIDOR (restringida
# por IP + API en Google Cloud); viaja en el header X-Goog-Api-Key, solo server-side.
# OJO: Routes API no tiene perfil de camión (usa modo DRIVE/auto).
GOOGLE_MAPS_SERVER_KEY=
# Tope defensivo de llamadas/día (defensa de facturación). Default: 2000.
GOOGLE_MAPS_MAX_DIARIO=2000

# --- SMTP (Nodemailer) ---
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_USER=alertas@tudominio.com
SMTP_PASSWORD=CAMBIAR
SMTP_FROM="FlotaOS <alertas@tudominio.com>"

# --- Correo: proveedor y remitente ---
# EmailService elige Brevo si hay BREVO_API_KEY; si no, usa SMTP (arriba).
EMAIL_FROM="FlotaOS <no-reply@tudominio.com>"
# --- Brevo (API transaccional) — opcional ---
BREVO_API_KEY=
# Remitente verificado en Brevo (obligatorio si usas Brevo).
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# --- IA generativa — opcional ---
# Proveedor compatible con OpenAI (por defecto Novita). Sin NOVITA_API_KEY las
# funciones de IA quedan deshabilitadas (los endpoints responden 503).
NOVITA_API_KEY=
# Base URL del proveedor (compatible OpenAI). Default: https://api.novita.ai/openai
AI_BASE_URL=https://api.novita.ai/openai
# Modelo multimodal (visión) para extracción de documentos: DEBE soportar
# imágenes. Default: qwen/qwen3-vl-30b-a3b-instruct (Qwen3-VL en Novita).
AI_VISION_MODEL=qwen/qwen3-vl-30b-a3b-instruct
# Páginas de PDF a leer en la extracción (default 4, tope 10). Más páginas =
# más tokens. Los PDF se rasterizan a imagen antes de mandarse al modelo.
AI_PDF_MAX_PAGINAS=4

# --- Bot / integraciones (n8n) — opcional ---
# API key para clientes de servicio (n8n). Va en el header X-Api-Key de los
# endpoints /api/bot/*. Sin ella, esos endpoints responden 503.
BOT_API_KEY=
# El geocoding del bot reusa GOOGLE_MAPS_SERVER_KEY (arriba): habilita la
# Geocoding API en ese proyecto de Google Cloud para que /api/bot/* funcione.

# --- Web (Next.js) ---
# NOTA: en producción la URL de API/WS se hornea en build como ruta relativa
# (ver docker-compose.build.yml), así que NO se configura aquí. Para correr el
# panel en desarrollo se usa apps/web/.env.local.
